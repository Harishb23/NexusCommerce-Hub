# PostgreSQL
POSTGRES_DB=commerceops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
ASPNETCORE_ENVIRONMENT=Docker
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=commerceops;Username=postgres;Password=postgres
AllowedOrigins=http://localhost:3000
Inventory__LowStockThreshold=10

# Frontend
VITE_API_URL=/api
